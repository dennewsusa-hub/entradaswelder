# Secret del webhook. Es el "Client secret" de la app en el Dev Dashboard de
# Shopify (dev.shopify.com/dashboard > tu app > Settings > Credentials).
SHOPIFY_WEBHOOK_SECRET=changeme

# Nombre de la pestaña del Google Sheet donde el cliente configura cuantas
# entradas da cada producto (opcional, default "rules"). El servicio la crea
# sola al arrancar si no existe.
# SWEEPSTAKES_RULES_SHEET=rules

# Puerto donde escucha el servidor
PORT=3000

# Token compartido para ver el panel de administracion de entradas (/admin/tickets)
ADMIN_TOKEN=changeme-admin-token

# Deja en "false" hasta tener el metodo de entrada gratuita (AMOE) resuelto legalmente.
# Ver README.md seccion "Aviso legal" antes de poner esto en true.
ENABLE_FREE_ENTRY=false

# Credenciales de la cuenta de servicio de Google (Google Cloud > IAM >
# Service Accounts). Ver README seccion "Configurar Google Sheets" para el
# paso a paso completo.
GOOGLE_SERVICE_ACCOUNT_EMAIL=nombre@tu-proyecto.iam.gserviceaccount.com

# La clave privada del JSON de la cuenta de servicio, con los saltos de linea
# como \n literal (asi es como Render y la mayoria de los paneles de env vars
# esperan que se pegue una clave multilinea en un solo valor).
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# El ID de la hoja de calculo (lo que va en la URL entre /d/ y /edit).
# La hoja debe tener una pestaña llamada exactamente "entries" y estar
# compartida con el email de la cuenta de servicio (rol Editor).
GOOGLE_SHEET_ID=changeme
