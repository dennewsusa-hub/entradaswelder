# Secret del webhook. Para custom apps es el "Client secret" de la pantalla
# Settings > Apps and sales channels > Develop apps > (tu app) > API credentials.
SHOPIFY_WEBHOOK_SECRET=changeme

# Puerto donde escucha el servidor
PORT=3000

# Token compartido para ver el panel de administracion de entradas (/admin/tickets)
ADMIN_TOKEN=changeme-admin-token

# Deja en "false" hasta tener el metodo de entrada gratuita (AMOE) resuelto legalmente.
# Ver README.md seccion "Aviso legal" antes de poner esto en true.
ENABLE_FREE_ENTRY=false
